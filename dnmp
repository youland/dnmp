#!/bin/bash
# ==============================================================================
# 极简 DNMP 自动部署脚本
# 特性：严格错误控制、动态智能测速换源、PHP 动态版本适配、服务模块化解耦
# dnmp.net
# bbs.dnmp.net
# ==============================================================================

# 开启安全锁：遇到任何未捕获错误立刻停止，防止带病运行
set -euo pipefail

# ==========================================
# 模块零：UI 与提示函数
# ==========================================
function print_red {
    echo -e -n "\e[1;31m$1\e[0m"
}
function print_green {
    echo -e -n "\e[1;32m$1\e[0m"
}
function print_info {
    echo -e -n "\e[1;36m$1\e[0m"
}
function print_warn {
    echo -e -n "\e[1;33m$1\e[0m"
}

# ==========================================
# 模块一：系统探针与环境检查
# ==========================================
function die {
    print_red "\n[!] 致命错误: $1\n"
    exit 1
}

function check_sanity {
    # 1. 检查是否为 Root 权限运行
    if [ $(/usr/bin/id -u) != "0" ]; then
        die 'Must be run by root user. 请使用 sudo 或 root 身份运行！'
    fi

    # 2. 系统探针：严格限定 Debian
    if [ -f /etc/os-release ]; then
        source /etc/os-release
        if [ "$ID" != "debian" ]; then
            die "当前系统是 $ID，本脚本专为 Debian 定制，不支持其他发行版！"
        fi
    else
        die "无法读取 /etc/os-release，当前系统太老或非标准 Linux！"
    fi
}

function get_hostip {
    # IPv4：使用阿里公共 DNS (223.5.5.5) 作为本地内核路由探针
    hostipv4=$(ip route get 223.5.5.5 2>/dev/null | grep -oP 'src \K\S+' || hostname -I | awk '{print $1}')
    
    # IPv6：使用阿里公共 DNS IPv6 (2400:3200::1) 作为本地内核路由探针
    hostipv6=$(ip -6 route get 2400:3200::1 2>/dev/null | grep -oP 'src \K\S+' || ip -6 address show | grep inet6 | grep -v -e '::1/128' -e 'fe80' | awk 'NR==1 {print $2}' | cut -d'/' -f1 || echo "")
}

function detect_region {
    print_info "[*] 正在探测服务器地理位置 (双节点 API + 三重特征校验)...\n"
    export IS_CHINA=0

    # 伪装请求头，防拦截
    local UA="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
    local detected=0

    # 定义三重匹配特征：中文"中国"、英文"China"、UTF-8十六进制的"中国"
    local cn_bytes=$'\xe4\xb8\xad\xe5\x9b\xbd'
    local match_pattern="中国|China|$cn_bytes"

    # ==========================================
    # 雷达一：IPIP.net (首选探测)
    # ==========================================
    local ip_info_1=""
    if command -v curl >/dev/null 2>&1; then
        ip_info_1=$(curl -4 -A "$UA" -sL -m 8 https://myip.ipip.net 2>/dev/null || echo "")
    else
        ip_info_1=$(wget -4 -U "$UA" -qO- -T 8 https://myip.ipip.net 2>/dev/null || echo "")
    fi

    # 执行三重特征匹配
    if echo "$ip_info_1" | grep -qE "$match_pattern"; then
        detected=1
        print_green "[√] 测速雷达 (IPIP)：命中特征！服务器位于国内。\n"
    else
        # ==========================================
        # 雷达二：cip.cc (备用容灾)
        # ==========================================
        local ip_info_2=""
        if command -v curl >/dev/null 2>&1; then
            ip_info_2=$(curl -4 -A "$UA" -sL -m 8 http://cip.cc 2>/dev/null || echo "")
        else
            ip_info_2=$(wget -4 -U "$UA" -qO- -T 8 http://cip.cc 2>/dev/null || echo "")
        fi

        # 执行三重特征匹配
        if echo "$ip_info_2" | grep -qE "$match_pattern"; then
            detected=1
            print_green "[√] 测速雷达 (cip.cc)：命中特征！服务器位于国内。\n"
        fi
    fi

    # ==========================================
    # 结果判定
    # ==========================================
    if [ "$detected" -eq 1 ]; then
        print_green "[*] 最终确认：将自动为您切换至国内镜像源。\n"
        export IS_CHINA=1
    else
        print_green "[*] 最终确认：未探测到国内特征，将使用全球官方源。\n"
    fi
}

function replace_system_sources {
    # 1. 动态获取当前 Debian 版本代号
    local CODENAME="${1:-}"
    if [ -z "$CODENAME" ]; then
        CODENAME=$(grep VERSION_CODENAME /etc/os-release | cut -d= -f2)
        if [ -z "$CODENAME" ]; then
            CODENAME="bookworm" # 默认保底
        fi
    fi

    # 针对 Debian 12 自动追加 non-free-firmware 组件
    local COMPONENTS="main contrib non-free"
    if [ "$CODENAME" = "bookworm" ]; then
        COMPONENTS="main contrib non-free non-free-firmware"
    fi

    print_info "[*] 正在重置 APT 基础源 (Codename: $CODENAME)...\n"

    # 2. 清空主文件sources.list，防范多源冲突
    if [ -f "/etc/apt/sources.list" ]; then
        mv /etc/apt/sources.list /etc/apt/sources.list.bak 2>/dev/null || true
        # 换成标准化注释指引
        echo "# See /etc/apt/sources.list.d/debian.list" > /etc/apt/sources.list
    fi

    # 3. 清掉旧格式源 (防范厂商自带的 .sources 冲突)
    rm -f /etc/apt/sources.list.d/debian.sources 2>/dev/null || true
    rm -f /etc/apt/sources.list.d/debian.list 2>/dev/null || true

    # 4. 覆盖重写 (全部输出到 debian.list)
    if [ "${IS_CHINA:-0}" -eq 1 ]; then
        print_info "[+] 检测到国内网络，正在写入清华大学镜像 (TUNA)...\n"
        cat << EOF > /etc/apt/sources.list.d/debian.list
deb https://mirrors.tuna.tsinghua.edu.cn/debian/ $CODENAME $COMPONENTS
deb https://mirrors.tuna.tsinghua.edu.cn/debian/ ${CODENAME}-updates $COMPONENTS
deb https://mirrors.tuna.tsinghua.edu.cn/debian/ ${CODENAME}-backports $COMPONENTS
deb https://mirrors.tuna.tsinghua.edu.cn/debian-security ${CODENAME}-security $COMPONENTS
EOF
    else
        print_info "[*] 海外网络，正在写入官方 Debian 镜像...\n"
        cat << EOF > /etc/apt/sources.list.d/debian.list
deb http://deb.debian.org/debian/ $CODENAME $COMPONENTS
deb http://deb.debian.org/debian/ ${CODENAME}-updates $COMPONENTS
deb http://deb.debian.org/debian/ ${CODENAME}-backports $COMPONENTS
deb http://security.debian.org/debian-security ${CODENAME}-security $COMPONENTS
EOF
    fi

    # 5. 保留树莓派的特殊处理 (兼容 .list 与 .sources 双格式)
    if [ "${IS_CHINA:-0}" -eq 1 ]; then
        print_info "  -> 检测到树莓派专用源，正在切换国内清华镜像...\n"
        
        # 处理旧版格式 (Bullseye 及以下)
        if [ -f "/etc/apt/sources.list.d/raspi.list" ]; then
            sed -i 's|http://archive.raspberrypi.com/debian/|https://mirrors.tuna.tsinghua.edu.cn/raspberrypi/|g' /etc/apt/sources.list.d/raspi.list 2>/dev/null || true
            sed -i 's|http://archive.raspberrypi.org/debian/|https://mirrors.tuna.tsinghua.edu.cn/raspberrypi/|g' /etc/apt/sources.list.d/raspi.list 2>/dev/null || true
        fi
        
        # 处理新版 DEB822 格式 (Bookworm 及以上)
        if [ -f "/etc/apt/sources.list.d/raspi.sources" ]; then
            sed -i 's|http://archive.raspberrypi.com/debian/|https://mirrors.tuna.tsinghua.edu.cn/raspberrypi/|g' /etc/apt/sources.list.d/raspi.sources 2>/dev/null || true
            sed -i 's|http://archive.raspberrypi.org/debian/|https://mirrors.tuna.tsinghua.edu.cn/raspberrypi/|g' /etc/apt/sources.list.d/raspi.sources 2>/dev/null || true
        fi
    fi

    print_green "[√] 系统镜像源重置完成！架构纯净！\n"
}

# ==========================================
# 模块二：包管理核心包装器
# ==========================================
function check_install {
    if [ -z "$(which "$1" 2>/dev/null)" ]; then
        DEBIAN_FRONTEND=noninteractive apt-get --no-install-recommends -q -y ${3:-} install $2
        print_info "$2 installed for $1\n"
    else
        print_warn "$2 already installed\n"
    fi
}

function check_remove {
    if [ -n "$(which "$1" 2>/dev/null)" ]; then
        DEBIAN_FRONTEND=noninteractive apt-get -q -y remove --purge "$2"
        print_info "$2 removed\n"
    else
        print_warn "$2 is not installed\n"
    fi
}

function update_upgrade {
    print_info "[+] 更新系统软件包列表...\n"
    apt-get -q -y update
}

# ==========================================
# 模块三：系统级配置与清理
# ==========================================
function setup_timezone {
    print_info "[+] 配置系统时区为 Asia/Shanghai...\n"
    ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime
}

function remove_unneeded {
    print_info "[+] 正在清理可能与 DNMP 冲突的服务 (如 Apache2, 遗留邮件服务等)...\n"
    
    # 清理抢占 80/443 端口的 Apache2
    if [ -n "$(which apache2 2>/dev/null)" ]; then
        systemctl stop apache2 2>/dev/null || true
        check_remove /usr/sbin/apache2 'apache2*'
    fi

    # 清理老旧的 Sendmail
    if [ -n "$(which sendmail 2>/dev/null)" ]; then
        systemctl stop sendmail 2>/dev/null || true
        check_remove /usr/sbin/sendmail 'sendmail*'
    fi

    # 清理遗留网络组件
    check_remove /usr/sbin/named bind9
    check_remove /usr/sbin/nscd nscd
    
    print_info "[+] 执行系统依赖瘦身 (autoremove)...\n"
    DEBIAN_FRONTEND=noninteractive apt-get -q -y autoremove --purge
    print_green "[√] 冲突清理与系统瘦身完毕！\n"
}

function config_ssh_port {
    print_info "[+] 配置 SSH 远程访问 (修改端口为 8066)...\n"
	
	# 确保 sshd_config.d 目录存在
    mkdir -p /etc/ssh/sshd_config.d/
	
    # 修改端口，使用drop-in模式，直接生成高优先级的专属配置文件，覆盖写入，保证幂等性
    cat <<EOF > /etc/ssh/sshd_config.d/99-dnmp-port.conf
# ==========================================
# DNMP 自定义 SSH 端口配置
# ==========================================
Port 8066
EOF

	# 身份验证策略
    cat <<EOF > /etc/ssh/sshd_config.d/99-dnmp-auth.conf
# ==========================================
# DNMP SSH 登录认证策略
# ==========================================
# 开启密钥登录支持
PubkeyAuthentication yes

# 初始允许密码登录 (⚠️ 强烈建议：配置好密钥并测试成功后，手动改为 no)
PasswordAuthentication yes
EOF

    # 重启服务使之生效
    systemctl restart ssh || systemctl restart sshd
    print_green "[√] SSH 端口 8066 配置并重启完毕！\n"
}

function opt_bbr() {
    print_info "正在执行底层网络调优 (BBR & Swap)..."

    # 1. 终极雷达：双重状态探测 (运行时状态 + 静态文件状态)
    # 探测 A：当前内核是否正在运行 BBR？
    local bbr_active=$(sysctl net.ipv4.tcp_congestion_control 2>/dev/null | grep -qw "bbr" && echo "yes" || echo "no")
    
    # 探测 B：全盘扫描历史配置文件 (涵盖 /etc/sysctl.conf 及 /etc/sysctl.d/ 下的所有文件)
    local bbr_configured=$(grep -qE "^net.ipv4.tcp_congestion_control\s*=\s*bbr" /etc/sysctl.conf /etc/sysctl.d/*.conf 2>/dev/null && echo "yes" || echo "no")

    if [ "$bbr_active" == "yes" ] || [ "$bbr_configured" == "yes" ]; then
        print_green "状态探测：系统内核已激活 BBR，或历史配置已存在，跳过重复覆盖！"
        return 0
    fi

    # 2. 探测物理内存与 Swap 护城河
    local total_mem=$(free -m | awk '/^Mem:/{print $2}')
    local total_swap=$(free -m | awk '/^Swap:/{print $2}')
    
    if [ "$total_mem" -le 1200 ] && [ "$total_swap" -eq 0 ]; then
        print_info "检测到低内存，正在挂载 1GB Swap..."
        fallocate -l 1G /swapfile && chmod 600 /swapfile && mkswap /swapfile >/dev/null 2>&1 && swapon /swapfile >/dev/null 2>&1
        grep -q "/swapfile" /etc/fstab || echo '/swapfile none swap sw 0 0' >> /etc/fstab
    fi

    local tcp_max
    if [ "$total_mem" -le 800 ]; then tcp_max=8388608
    elif [ "$total_mem" -le 1500 ]; then tcp_max=16777216
    else tcp_max=33554432; fi

    # 3. 规范化配置：采用drop-in模式配置bbr
local SYSCTL_CONF="/etc/sysctl.d/99-bbr.conf"
    
    cat <<EOF > ${SYSCTL_CONF}
# ==========================================
# 极限网络底层压榨 (完全体 BBR 与高并发调优)
# ==========================================
# 1. BBR 与 吞吐量队列策略
net.core.default_qdisc = fq
net.ipv4.tcp_congestion_control = bbr
net.ipv4.tcp_mtu_probing = 1
net.core.rmem_max = ${tcp_max}
net.core.wmem_max = ${tcp_max}
net.ipv4.tcp_rmem = 4096 87380 ${tcp_max}
net.ipv4.tcp_wmem = 4096 16384 ${tcp_max}
net.ipv4.tcp_adv_win_scale = -2
net.ipv4.tcp_notsent_lowat = 131072

# 2. 高并发连接池扩容 (防丢包/断流)
net.core.somaxconn = 8192
net.core.netdev_max_backlog = 8192
net.ipv4.tcp_max_syn_backlog = 8192

# 3. 内存极速回收机制 (专为跨洋代理/短连接优化)
net.ipv4.tcp_fastopen = 3
net.ipv4.tcp_tw_reuse = 1
net.ipv4.tcp_fin_timeout = 15
net.ipv4.tcp_keepalive_time = 300
net.ipv4.tcp_keepalive_probes = 5
net.ipv4.tcp_keepalive_intvl = 15
net.ipv4.tcp_max_tw_buckets = 32768
net.ipv4.ip_local_port_range = 10000 65000
EOF

    sysctl --system >/dev/null 2>&1
    print_green "底层bbr网络调优完成，配置文件在 ${SYSCTL_CONF}！"
}

# ==========================================
# 模块四：智能软件源分发路由 (Sury 源)
# ==========================================
function _add_sury_source_core {
    local sury_base="$1"
    print_info "[+] 正在写入 Sury 软件源，基础地址: $sury_base\n"
    
    apt-get -y install lsb-release ca-certificates curl
    
    curl -sSLo /tmp/debsuryorg-archive-keyring.deb "${sury_base}/debsuryorg-archive-keyring.deb"
    dpkg -i /tmp/debsuryorg-archive-keyring.deb
    
    sh -c "echo \"deb [signed-by=/usr/share/keyrings/debsuryorg-archive-keyring.gpg] ${sury_base}/nginx/ \$(lsb_release -sc) main\" > /etc/apt/sources.list.d/nginx.list"
    sh -c "echo \"deb [signed-by=/usr/share/keyrings/debsuryorg-archive-keyring.gpg] ${sury_base}/php/ \$(lsb_release -sc) main\" > /etc/apt/sources.list.d/php.list"
    
    apt-get update
}

function add_app_sources {
    # 读取雷达信号，智能分发
    if [ "${IS_CHINA:-0}" -eq 1 ]; then
        print_green "[*] 使用国内策略：调用上海交大镜像源\n"
        _add_sury_source_core "https://mirror.sjtu.edu.cn/sury"
    else
        print_green "[*] 使用海外策略：调用全球官方源\n"
        _add_sury_source_core "https://packages.sury.org"
    fi
}

