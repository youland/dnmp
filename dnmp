function get_password() {
    SALT=/var/lib/random_salt
    if [ ! -f "$SALT" ]; then
        head -c 512 /dev/urandom > "$SALT"
        chmod 400 "$SALT"
    fi
    password=$( (cat "$SALT"; echo "$1") | md5sum | base64 )
    echo "${password:0:13}"
}

function install_mysql {
    print_info "[+] 开始安装 MariaDB...\n"
    check_install mysqld "mariadb-server"
    check_install mysql "mariadb-client"
    
    systemctl stop mariadb
    systemctl status mariadb &>/dev/null && echo "mariadb running..." || echo "mariadb stopped..."

    cat > /etc/mysql/conf.d/dnmp.cnf <<END
[server]
skip-name-resolve
innodb_buffer_pool_size = 128M
innodb_buffer_pool_instances = 1
innodb_flush_log_at_trx_commit = 2
innodb_log_buffer_size = 32M
innodb_max_dirty_pages_pct = 90
query_cache_type = 1
query_cache_limit = 2M
query_cache_min_res_unit = 2k
query_cache_size = 64M
tmp_table_size= 64M
max_heap_table_size= 64M
slow-query-log = 1
slow-query-log-file = /var/log/mysql/slow.log
long_query_time = 1

[client-server]

[client]
default-character-set = utf8mb4

[mysqld]
character-set-server = utf8mb4
collation-server = utf8mb4_general_ci
transaction_isolation = READ-COMMITTED
binlog_format = ROW
innodb_file_per_table=1
END

    systemctl start mariadb
    systemctl status mariadb &>/dev/null && print_green "[√] MariaDB 已成功启动！\n" || print_red "[-] MariaDB 启动失败！\n"

    if [ ! -e ~/.my.cnf ]; then
        passwd=$(get_password root@mysql)
        mysqladmin password "$passwd" || true
        cat > ~/.my.cnf <<END
[client]
user = root
password = $passwd
END
    fi
    chmod 600 ~/.my.cnf
}

function install_nginx {
    check_install nginx "nginx"
	
	echo -e "\n\033[36m[+] 正在写入优化版 Nginx.conf 全局配置...\033[0m"
	
    cat << 'EOF' > /etc/nginx/nginx.conf
user www-data;
worker_processes auto;
pid /var/run/nginx.pid;

worker_rlimit_nofile 10240;

events {
    use epoll;
    worker_connections 2000;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    # 安全加固，隐藏 Nginx 版本号
    server_tokens off; 

    server_name_in_redirect off;
    server_names_hash_bucket_size 64;
    client_header_buffer_size 1k;
    client_max_body_size 100M;
    large_client_header_buffers 4 4k;
 
    sendfile        on;
    tcp_nopush      on;
 
    client_body_timeout 10;
    client_header_timeout 10;
    send_timeout 60;
 
    # 配合 HTTP/2，将 Keepalive 适当调大至 65 秒
    keepalive_timeout  65;
    tcp_nodelay        on;
 
    output_buffers 1 32k;
    postpone_output 1460;
 
    open_file_cache max=2000 inactive=20s;
    open_file_cache_min_uses 1;
    open_file_cache_valid 30s;

    fastcgi_connect_timeout 300;
    fastcgi_send_timeout 300;
    fastcgi_read_timeout 300;
    fastcgi_buffer_size 64k;
    fastcgi_buffers 4 64k;
    fastcgi_busy_buffers_size 128k;
    fastcgi_temp_file_write_size 128k;

    # ==========================================
    # Gzip 终极调优 (针对单页应用与 API)
    # ==========================================
    gzip on;
    gzip_min_length  1k;
    gzip_buffers     4 16k;
    gzip_http_version 1.1;
    
    # 压缩级别设定为 5，平衡 CPU 算力与网络带宽
    gzip_comp_level 5;
    
    # 全面覆盖 JSON 与现代前端资源
    gzip_types       text/plain text/css application/json application/javascript application/x-javascript text/xml application/xml application/xml+rss text/javascript image/svg+xml;
    
    # 适配前端 CDN 缓存代理
    gzip_vary on;
    gzip_disable "MSIE [1-6]\.";

    # ==========================================
    # 全局 SSL 性能优化
    # ==========================================
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    
    # 开辟 50MB 超大 SSL 缓存池，由所有站点共享，榨干握手性能
    ssl_session_cache shared:SSL:50m; 
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    # 日志格式定义 (此处的 $ 符号受单引号 EOF 保护，不会丢失)
    log_format  dnmplogs      '$remote_addr - [$time_local] "$request" '
                              '$status $body_bytes_sent "$http_referer"'
                              '"$http_user_agent" $http_x_forwarded_for';
    access_log /var/log/nginx/access.log dnmplogs;
    error_log /var/log/nginx/error.log;

    include /etc/nginx/conf.d/*.conf;
    include /etc/nginx/sites-enabled/*;
}
EOF

	echo -e "\033[32m[√] Nginx.conf 配置写入完成！\033[0m"

    if [ ! -d /etc/nginx/sites-available ]; then
        mkdir -p /etc/nginx/sites-available
    fi
    if [ ! -d /etc/nginx/sites-enabled ]; then
        mkdir -p /etc/nginx/sites-enabled
    fi
    
    cat > /etc/nginx/sites-enabled/default <<END
# ==========================================
# 全局防线 只允许精确通过 IP 访问面板
# 作用：展示控制台面板
# ==========================================
server {
    listen 80;
    server_name ${hostipv4};
    
	# default 根目录
    root /var/www/default;
    index index.html index.htm index.php;
	
	# PHP 处理探针
    include /etc/nginx/fastcgi_php;
	
	# 访问日志 (调用全局 dnmplogs 格式)
    access_log /var/log/nginx/default.access.log dnmplogs;
}

# ==========================================
# HTTP (80) 阻断：阻断所有未配置的解析域名
# ==========================================
server {
    listen 80 default_server;
    server_name _;

    # ACME 验证通道
    include /etc/nginx/acme_challenge.conf;    

    #  除 ACME 以外的所有访问，直接拔网线！
    location / {
        return 444; 
    }	
}

# ==========================================
# HTTPS (443) 终极黑洞：拒绝所有 SSL 握手
# ==========================================
server {
    listen 443 ssl default_server;
    server_name _;

    # 🔴 在底层斩断 TCP 握手！
    ssl_reject_handshake on;
}
END

	# ==========================================
    # 注入：全局 ACME 续签模块
    # ==========================================
    echo -e "\033[1;36m[*] 正在生成 Nginx 全局 ACME 验证模块...\033[0m"
    
    # 确保验证文件的目录存在
    mkdir -p /var/www/default/.well-known/acme-challenge/
    chown -R www-data:www-data /var/www/default
    
    # 写入公共配置文件
    cat << 'EOF' > /etc/nginx/acme_challenge.conf
# --------------------------------------------------------
# Let's Encrypt / ACME 全局验证通道
# 作用：拦截所有 .well-known 请求，统一转入 default 目录
# 需要在域名配置文件加入这一行：
#   include /etc/nginx/acme_challenge.conf;
# --------------------------------------------------------
location ^~ /.well-known/acme-challenge/ {
    allow all;
    root /var/www/default;
    # 关闭日志，防止每次验证产生垃圾日志
    access_log off;
    log_not_found off;
}
EOF
    echo -e "\033[0;32m[√] 全局 ACME 模块 (/etc/nginx/acme_challenge.conf) 部署完毕！\033[0m"
	
	
	# ==========================================
    # Nginx额外配置模块
    # ==========================================
    if [ ! -f /etc/nginx/conf.d/discuzx ]; then
        print_info "[+] 正在拉取 Nginx 配置文件...\n"
        mkdir -p /etc/nginx/conf.d
        
        # 第一次清空目录，为拉取腾出纯净空间
        rm -rf /etc/nginx/conf.d/*

        # 尝试通道 A：GitHub (专属镜像，完美适配洛杉矶海外网络)
        env GIT_TERMINAL_PROMPT=0 git clone --depth 1 https://github.com/youland/nginx_conf.git /etc/nginx/conf.d >/dev/null 2>&1 || true

        # 判定通道 A 是否成功 (通过检查是否生成了 .git 隐藏目录)
        if [ ! -d /etc/nginx/conf.d/.git ]; then
            print_warn "[-] GitHub 节点拉取配置超时或失败，秒切 Gitee 备用通道...\n"
            
            # 极客细节：必须再次清理战场，防止 GitHub 留下残缺文件导致 Gitee 克隆报错
            rm -rf /etc/nginx/conf.d/*
            
            # 尝试通道 B：Gitee 仓库
            env GIT_TERMINAL_PROMPT=0 git clone --depth 1 https://gitee.com/nbweb/nginx_conf.git /etc/nginx/conf.d >/dev/null 2>&1 || true
        fi

        # 验证与清理
        if [ -d /etc/nginx/conf.d/.git ]; then
            # 阅后即焚：销毁 Git 追踪文件夹，保持 Nginx 配置目录的绝对纯净
            rm -rf /etc/nginx/conf.d/.git
            print_green "[√] Nginx 配置文件拉取并部署完毕！\n"
        else
            print_red "[!] Nginx 配置文件双通道拉取均失败，请检查网络或仓库状态。\n"
        fi
    fi

    chown www-data:www-data -R /var/www
    chmod g+s -R /var/www/.
}

