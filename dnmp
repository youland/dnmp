function install_phpmyadmin {
    print_info "[+] 安装 phpMyAdmin...\n"
    mkdir -p /var/www/default /etc/dnmp
    
    if [ ! -d "/etc/dnmp/phpmyadmin" ]; then
        local pma_ver
        pma_ver=$(curl -4 -sL -m 10 https://www.phpmyadmin.net/home_page/version.txt | head -n 1 || true)
        
        # 兜底版本
        if [ -z "$pma_ver" ]; then
            print_warn "[-] 无法连接官网获取最新版本号，将启用默认兜底版本 5.2.3...\n"
            pma_ver="5.2.3"
        fi
        
        local pma_url="https://files.phpmyadmin.net/phpMyAdmin/${pma_ver}/phpMyAdmin-${pma_ver}-all-languages.tar.gz"
        local tmp_tar="/tmp/phpmyadmin_${pma_ver}.tar.gz"
        local extract_dir="/tmp/phpMyAdmin-${pma_ver}-all-languages"
        
        print_info "[*] 正在拉取 phpMyAdmin ${pma_ver} (启用实体落地与断点续传模式)...\n"
        
        # 【核心重构】抛弃脆弱的管道直解压，改为下载实体文件
        # 参数解析：-c (支持断点续传)  -t 3 (重试3次)  -T 15 (单次连接超时15秒)
        if wget -4 -c -t 3 -T 15 -O "$tmp_tar" "$pma_url"; then
            print_info "[+] 下载完成，正在校验文件完整性...\n"
            
            # 测试解压包是否完好无损，防止下载了残缺包导致 tar 报错
            if tar -tf "$tmp_tar" >/dev/null 2>&1; then
                # 校验通过，开始真正的解压
                tar -zxf "$tmp_tar" -C /tmp/
                mv "$extract_dir" "/etc/dnmp/phpmyadmin"
                ln -sf /etc/dnmp/phpmyadmin /var/www/default/phpmyadmin
                
                # 清理临时压缩包
                rm -f "$tmp_tar"
                print_green "[√] phpMyAdmin ${pma_ver} 部署完毕！\n"
            else
                print_red "[!] 压缩包校验失败 (文件损坏或被劫持)，已清理残骸，请下次重试。\n"
                rm -f "$tmp_tar"
            fi
        else
            print_red "[!] 遭遇严重网络阻断，安全跳过。已保留下载进度，下次执行将断点续传。\n"
            # 极客细节：这里故意不执行 rm -f "$tmp_tar"
            # 这样你下次再运行脚本时，wget -c 会自动识别并从中断的 % 继续下载！
        fi
    else
        print_warn "[-] phpMyAdmin 已存在，跳过安装。\n"
    fi
}

