# ==========================================
# 模块：Redis 服务端与 PHP 扩展安装
# 特性：智能内存分配、Drop-in 配置、基础调优、完整错误处理
# ==========================================
function install_redis() {
    print_info "[+] 正在部署 Redis 内存数据库与 PHP 扩展...\n"
	
	# 动态探测当前的 PHP 版本    
    if [ -z "${ACTUAL_PHP_V:-}" ]; then
        if command -v php >/dev/null 2>&1; then
            ACTUAL_PHP_V=$(php -v | head -n 1 | awk '{print $2}' | cut -d. -f1,2)
        else
            # 如果 php 还没装，默认版本是 8.2
            ACTUAL_PHP_V="8.2"
        fi
    fi

    # 安装 Redis 服务端和 PHP 扩展
    print_info "  -> 正在校验并安装核心组件...\n"
    apt-get update -y >/dev/null 2>&1
    
    # 用 check_install 安装 redis-server
    check_install redis-server "redis-server"
    
    # PHP 扩展无独立命令，直接静默安装保证幂等
    DEBIAN_FRONTEND=noninteractive apt-get --no-install-recommends -q -y install "php${ACTUAL_PHP_V}-redis" >/dev/null 2>&1

    # 打印当前安装的版本号
    local redis_ver=$(redis-server --version 2>/dev/null | awk '{print $3}' || echo "Unknown")
    print_info "  -> 当前 Redis 版本: ${redis_ver}\n"
	
	# PHP 扩展安装完成日志
    print_info "  -> php${ACTUAL_PHP_V}-redis 已安装完成\n"

    # 智能内存分配
    local total_mem=$(free -m | awk '/^Mem:/{print $2}')
    local redis_max_mem="128mb"

    if [ "$total_mem" -le 512 ]; then
        redis_max_mem="64mb"
    elif [ "$total_mem" -le 1024 ]; then
        redis_max_mem="128mb"
    elif [ "$total_mem" -le 2048 ]; then
        redis_max_mem="256mb"
    elif [ "$total_mem" -le 4096 ]; then
        redis_max_mem="512mb"
    else
        redis_max_mem="1024mb"
    fi

    print_info "  -> 系统物理内存 ${total_mem}MB，为 Redis 分配安全上限 ${redis_max_mem}\n"

    #  Drop-in 配置（推荐方式）
    local REDIS_CONF_DIR="/etc/redis/redis.conf.d"
    mkdir -p ${REDIS_CONF_DIR}

    cat > ${REDIS_CONF_DIR}/99-dnmp-redis.conf <<EOF
# ==========================================
# DNMP Redis 智能配置 - 内存保护与调优
# ==========================================
maxmemory ${redis_max_mem}
maxmemory-policy allkeys-lru
# 基础性能优化
tcp-keepalive 60
timeout 0
tcp-backlog 128
EOF

    # 确保主配置文件包含 drop-in
    if ! grep -q "include ${REDIS_CONF_DIR}/" /etc/redis/redis.conf; then
        echo "" >> /etc/redis/redis.conf
        echo "# DNMP Redis Drop-in 配置" >> /etc/redis/redis.conf
        echo "include ${REDIS_CONF_DIR}/*.conf" >> /etc/redis/redis.conf
    fi

    # 重启服务并设置开机自启
    systemctl restart redis-server
    systemctl enable redis-server >/dev/null 2>&1
	systemctl status redis-server &>/dev/null && echo -e "  \e[1;32mredis-server running... [√]\e[0m" || echo -e "  \e[1;31mredis-server stopped... [×]\e[0m"

    # 重启 PHP-FPM 让扩展生效
    if [ -n "${ACTUAL_PHP_V:-}" ]; then
        systemctl restart php${ACTUAL_PHP_V}-fpm >/dev/null 2>&1 || true
		systemctl status php${ACTUAL_PHP_V}-fpm &>/dev/null && echo -e "  \e[1;32mphp${ACTUAL_PHP_V}-fpm running... [√]\e[0m" || echo -e "  \e[1;31mphp${ACTUAL_PHP_V}-fpm stopped... [×]\e[0m"
    fi

    # 最终验证
    if systemctl is-active --quiet redis-server; then
        print_green "[√] Redis 部署完成！已智能分配 ${redis_max_mem} 内存保护\n"
    else
        print_red "[!] Redis 启动失败，请检查日志：journalctl -u redis-server\n"
    fi
}

# ==========================================
# 模块六：辅助工具安装 (DNMP 壳与 PHPMyAdmin)
# ==========================================
function install_phpmyadmin {
    print_info "[+] 安装 phpMyAdmin...\n"
    mkdir -p /var/www/default /etc/dnmp
    
    if [ ! -d "/etc/dnmp/phpmyadmin" ]; then
        local pma_ver
        pma_ver=$(curl -4 -sL -m 10 https://www.phpmyadmin.net/home_page/version.txt | head -n 1 || true)
        
        # 兜底版本
        if [ -z "$pma_ver" ]; then
            print_warn "[-] 无法连接官网获取最新版本号，将启用默认兜底版本 5.2.3...\n"
            pma_ver="5.2.3"
        fi
        
        local pma_url="https://files.phpmyadmin.net/phpMyAdmin/${pma_ver}/phpMyAdmin-${pma_ver}-all-languages.tar.gz"
        local tmp_tar="/tmp/phpmyadmin_${pma_ver}.tar.gz"
        local extract_dir="/tmp/phpMyAdmin-${pma_ver}-all-languages"
        
        print_info "[*] 正在拉取 phpMyAdmin ${pma_ver} (启用实体落地与断点续传模式)...\n"
        
        # 【核心重构】抛弃脆弱的管道直解压，改为下载实体文件
        # 参数解析：-c (支持断点续传)  -t 3 (重试3次)  -T 15 (单次连接超时15秒)
        if wget -4 -c -t 3 -T 15 -O "$tmp_tar" "$pma_url"; then
            print_info "[+] 下载完成，正在校验文件完整性...\n"
            
            # 测试解压包是否完好无损，防止下载了残缺包导致 tar 报错
            if tar -tf "$tmp_tar" >/dev/null 2>&1; then
                # 校验通过，开始真正的解压
                tar -zxf "$tmp_tar" -C /tmp/
                mv "$extract_dir" "/etc/dnmp/phpmyadmin"
                ln -sf /etc/dnmp/phpmyadmin /var/www/default/phpmyadmin
                
                # 清理临时压缩包
                rm -f "$tmp_tar"
                print_green "[√] phpMyAdmin ${pma_ver} 部署完毕！\n"
            else
                print_red "[!] 压缩包校验失败 (文件损坏或被劫持)，已清理残骸，请下次重试。\n"
                rm -f "$tmp_tar"
            fi
        else
            print_red "[!] 遭遇严重网络阻断，安全跳过。已保留下载进度，下次执行将断点续传。\n"
            # 极客细节：这里故意不执行 rm -f "$tmp_tar"
            # 这样你下次再运行脚本时，wget -c 会自动识别并从中断的 % 继续下载！
        fi
    else
        print_warn "[-] phpMyAdmin 已存在，跳过安装。\n"
    fi
}

