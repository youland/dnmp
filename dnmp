function install_docker {
    print_info "[+] 正在检查并部署 Docker 容器环境...\n"

    # 1. 幂等性检查：如果已经安装，则直接跳过
    if command -v docker &> /dev/null; then
        print_warn "[-] Docker 已处于安装状态，跳过部署。\n"
        print_info "  -> 当前版本: $(docker --version)\n"
        return
    fi

    # 2. 清理历史包：防止系统自带的残缺版或旧版冲突
    print_info "  -> 正在清理潜在的旧版本冲突残留...\n"
    apt-get remove -y docker.io docker-doc docker-compose podman-docker containerd runc >/dev/null 2>&1 || true

    # 3. 安装必备的依赖组件
    print_info "  -> 正在安装底层依赖证书与密钥管理工具...\n"
    apt-get update >/dev/null 2>&1
    apt-get install -y ca-certificates curl gnupg lsb-release

    # 4. 导入官方 GPG 密钥
    print_info "  -> 正在导入 Docker 官方 GPG 密钥...\n"
    install -m 0755 -d /etc/apt/keyrings
    curl -4 -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor --yes -o /etc/apt/keyrings/docker.gpg
    chmod a+r /etc/apt/keyrings/docker.gpg

    # 5. 动态写入 Debian 专属的 APT 仓库源
    print_info "  -> 正在配置 Docker 官方 APT 仓库源...\n"
    echo \
      "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian \
      $(lsb_release -cs) stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null

    # 6. 开始核心安装 (包含最新的 Compose V2 插件)
    print_info "  -> 开始拉取并安装 Docker 核心组件 (Engine & Compose)...\n"
    apt-get update >/dev/null 2>&1
    # 安装 Docker 引擎、CLI 工具、Containerd 运行时，以及新版 Compose 插件
    apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

    # 7. 启动并配置开机自启
    systemctl enable docker >/dev/null 2>&1
    systemctl start docker >/dev/null 2>&1

    # 8. 终极验证
    if command -v docker &> /dev/null; then
        print_green "[√] Docker 环境部署成功！\n"
        print_info "  -> 引擎版本: $(docker --version)\n"
        print_info "  -> 编排版本: $(docker compose version)\n"
    else
        print_red "[!] Docker 安装失败，请检查网络或源配置。\n"
    fi
}

function install_portainer {
    print_info "[+] 正在部署 Portainer 图形化管理面板...\n"

    # 1. 检查 Portainer 是否已在运行
    if docker ps -a | grep -q "portainer"; then
        print_warn "[-] Portainer 容器已存在，跳过安装。\n"
        return
    fi

    # 2. 创建持久化数据卷 (防止容器重启后配置丢失)
    print_info "  -> 创建持久化数据卷: portainer_data\n"
    docker volume create portainer_data >/dev/null 2>&1

    # 3. 一键拉取并运行 (使用社区商业版 CE，完全免费且功能最强)
    print_info "  -> 正在拉取并启动容器 (容器内端口 9000)...\n"
    
    # 映射 9000 端口
    docker run -d \
      -p 9090:9000 \
      -p 8000:8000 \
      --name portainer \
      --restart always \
      -v /var/run/docker.sock:/var/run/docker.sock \
      -v portainer_data:/data \
      portainer/portainer-ce:latest >/dev/null 2>&1

    # 4. 验证状态
    if [ "$(docker inspect -f '{{.State.Running}}' portainer)" == "true" ]; then
        print_green "[√] Portainer 部署成功！\n"
        # 自动获取当前机器的 IP
        local REMOTE_IP=$(ip route get 1.1.1.1 2>/dev/null | grep -oP 'src \K\S+' || hostname -I | awk '{print $1}')
        print_info "  -> 管理地址: http://${REMOTE_IP}:9090\n"
        print_warn "  -> 请尽快登录设置管理员密码 (初次登录需在 5 分钟内完成)。\n"
    else
        print_red "[!] Portainer 启动失败，请检查 Docker 日志。\n"
    fi
}

# ==========================================
# 模块：Acme.sh 智能双模 SSL 部署 (原生/独立)
# 特性：自动嗅探 Nginx 状态，支持防报错自愈注入，统一 .key/.cer 后缀
# ==========================================
function deploy_acme() {
    local DOMAIN=$1
    if [ -z "$DOMAIN" ]; then
        echo -e "\033[0;31m[!] 致命错误：未指定域名！\033[0m"
        echo -e "\033[1;33m[*] 用法示例: bash dnmp acme dnmp.net\033[0m"
        exit 1
    fi

    local EMAIL="admin@${DOMAIN}"
    local SSL_DIR="/etc/nginx/ssl/${DOMAIN}"

    echo -e "\033[1;36m==========================================\033[0m"
    echo -e "\033[1;36m      开始为原生网站 ${DOMAIN} 部署 SSL 证书      \033[0m"
    echo -e "\033[1;36m==========================================\033[0m"

    # 1. 安装 acme.sh 及必要依赖
    if [ ! -f ~/.acme.sh/acme.sh ]; then
        echo -e "\033[1;33m[*] 未检测到 acme.sh，正在安装依赖和 acme.sh...\033[0m"
        
        # 安装必要依赖
        apt update -y
        apt install -y curl socat psmisc openssl ca-certificates

        echo -e "\033[1;33m[*] 正在安装 acme.sh（使用 IPv4 强制 + 超时保护）...\033[0m"
        
        # 使用 IPv4 强制 + 超时 + 显示进度
        curl -4 -sSL --connect-timeout 15 --max-time 60 https://get.acme.sh | sh -s email=${EMAIL}
        
        if [ $? -ne 0 ]; then
            echo -e "\033[0;33m[!] 官方源安装失败，尝试 Gitee 镜像加速...\033[0m"
            curl -4 -sSL --connect-timeout 15 https://gitee.com/neilpang/acme.sh/raw/master/acme.sh | sh -s email=${EMAIL}
        fi

        # 加载 acme.sh 专属环境变量（比 source ~/.bashrc 安全且绝对生效）
        if [ -f "${HOME}/.acme.sh/acme.sh.env" ]; then
            source "${HOME}/.acme.sh/acme.sh.env"
        fi

        if [ -f ~/.acme.sh/acme.sh ]; then
            ~/.acme.sh/acme.sh --set-default-ca --server letsencrypt
            echo -e "\033[0;32m[√] acme.sh 安装成功！\033[0m"
        else
            echo -e "\033[0;31m[!] acme.sh 安装失败，请检查网络连接或手动安装。\033[0m"
            return 1
        fi
    else
        echo -e "\033[0;32m[√] acme.sh 已存在，跳过安装。\033[0m"
    fi

    # 创建证书目录
    mkdir -p ${SSL_DIR}

    # 2. 签发证书逻辑
    if systemctl is-active --quiet nginx; then
        echo -e "\033[1;33m[*] 检测到 Nginx 正在运行，使用 --webroot 模式...\033[0m"

        # 确保有域名占位配置
        if ! grep -qR "server_name.*${DOMAIN}" /etc/nginx/ 2>/dev/null; then
            echo -e "\033[1;33m[*] 生成 ${DOMAIN} Nginx 占位配置...\033[0m"
            cat <<EOF > /etc/nginx/sites-enabled/${DOMAIN}.conf
server {
    listen 80;
    server_name ${DOMAIN};
    root /var/www/default;
}
EOF
            systemctl reload nginx >/dev/null 2>&1
        fi

        ~/.acme.sh/acme.sh --issue -d ${DOMAIN} --webroot /var/www/default

        if [ $? -eq 0 ]; then
            ~/.acme.sh/acme.sh --install-cert -d ${DOMAIN} --ecc \
                --key-file      ${SSL_DIR}/${DOMAIN}.key \
                --fullchain-file ${SSL_DIR}/${DOMAIN}.cer \
                --reloadcmd     "systemctl reload nginx" >/dev/null 2>&1
            
            echo -e "\033[0;32m[√] SSL 证书部署成功！\033[0m"
            echo -e "\033[1;36m   → 证书路径: ${SSL_DIR}\033[0m"
            echo -e "\033[1;36m   → HTTPS 地址: https://${DOMAIN}\033[0m"
        else
            echo -e "\033[0;31m[!] Nginx 模式签发失败！请检查域名 A 记录是否正确指向本机 IP。\033[0m"
            return 1
        fi
    else
        echo -e "\033[1;33m[*] 未检测到 Nginx，使用 standalone 模式...\033[0m"
        
        fuser -k 80/tcp >/dev/null 2>&1 || true
        
        ~/.acme.sh/acme.sh --issue -d ${DOMAIN} --standalone --keylength ec-256
        
        if [ $? -eq 0 ]; then
            ~/.acme.sh/acme.sh --install-cert -d ${DOMAIN} --ecc \
                --key-file      ${SSL_DIR}/${DOMAIN}.key \
                --fullchain-file ${SSL_DIR}/${DOMAIN}.cer \
                --reloadcmd     "systemctl reload nginx >/dev/null 2>&1 || true" >/dev/null 2>&1
            
            echo -e "\033[0;32m[√] SSL 证书部署成功！\033[0m"
			
			# ==============================================================
            # 🚀 自动化生成并注入最终的生产级 Nginx 业务配置
            # ==============================================================
            local NGINX_CONF="/etc/nginx/sites-enabled/${DOMAIN}.conf"
            local WEB_ROOT="/var/www/${DOMAIN}"
            
            echo -e "\033[1;36m[*] 证书部署完毕，正在为您自动生成 Nginx 配置...\033[0m"
            
            # 1. 创建专属目录
            mkdir -p ${WEB_ROOT}
            chown -R www-data:www-data ${WEB_ROOT}
            
            # 2. 动态写入配置 (完美融合 80跳转 与 443承载)
            cat <<EOF > ${NGINX_CONF}
# ==========================================
# HTTP (80) - 负责接收、验证与强制带路
# ==========================================
server {
    listen 80;
    server_name ${DOMAIN};

    # 🟢 引入全局 Let's Encrypt 验证防线，用于域名ssl证书续签
    include /etc/nginx/acme_challenge.conf;

    # 🔴 强制跳转：正常访客一律强制到 HTTPS
    location / {
        return 301 https://${DOMAIN}\$request_uri;
    }
}

# ==========================================
# HTTPS (443) - 加密流量
# ==========================================
server {
    listen 443 ssl;
    server_name ${DOMAIN};
    
    # 物理路径
    root ${WEB_ROOT};
    index index.html index.htm index.php;

    # SSL 证书配置
    ssl_certificate ${SSL_DIR}/${DOMAIN}.cer;
    ssl_certificate_key ${SSL_DIR}/${DOMAIN}.key;
    
    # SSL 性能与安全优化
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers TLS13-AES-256-GCM-SHA384:TLS13-CHACHA20-POLY1305-SHA256:TLS13-AES-128-GCM-SHA256:EECDH+CHACHA20:EECDH+ECDSA+AES128:EECDH+aRSA+AES128:RSA+AES128:EECDH+ECDSA+AES256:EECDH+aRSA+AES256:RSA+AES256:EECDH+ECDSA+3DES:EECDH+aRSA+3DES:RSA+3DES:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:50m;
    ssl_session_timeout 1d;
    ssl_session_tickets on;

    # 核心业务逻辑调度
    include /etc/nginx/fastcgi_php;
    
    # 💡 伪静态扩展区 (按需取消注释)
    # include /etc/nginx/conf.d/discuzx;
    # include /etc/nginx/conf.d/wordpress;

    # 独立日志隔离
    access_log /var/log/nginx/${DOMAIN}.access.log dnmplogs;
    error_log  /var/log/nginx/${DOMAIN}.error.log;
}
EOF
            
            # 3. 终极重载生效
            systemctl reload nginx >/dev/null 2>&1
            echo -e "\033[0;32m[√] 完美闭环！${DOMAIN}.conf 已生效，目录 ${WEB_ROOT} 已准备就绪！\033[0m"
            echo -e "\033[1;36m   → 您现在可以直接上传代码建站了: https://${DOMAIN}\033[0m"
            # ==============================================================
        else
            echo -e "\033[0;31m[!] Standalone 模式签发失败！请确认 80 端口未被占用。\033[0m"
            return 1
        fi
    fi
}

# ==========================================
# 模块八：交互式数据库创建向导 (免密 + 手动盲打双重防御)
# ==========================================
function create_new_db() {
    echo "===================================================="
    echo "🚀 DNMP 安全数据库创建向导"
    echo "===================================================="

    # --------------------------------------------------
    # 0. 核心探针：双通道连通性测试 (Fail-Fast 机制)
    # --------------------------------------------------
    echo "🔍 正在检测底层 MySQL/MariaDB 免密连通性..."
    
    USE_MANUAL_PASS=false

    # [通道 A] 尝试 ~/.my.cnf 免密连接
    if mysql -e "SELECT 1;" >/dev/null 2>&1; then
        echo "✅ 免密通道畅通，引擎响应正常！"
        echo "----------------------------------------------------"
    else
        # [通道 B] 免密失败，降级为手动验证
        echo "⚠️ 免密通道失效或未配置。启动手动后备方案..."
        echo "💡 提示: 终端已开启静默防窥模式，输入密码时屏幕不会显示任何字符（包括星号），请放心盲打。"
        echo "----------------------------------------------------"
        
        # 第一次输入
        read -s -p "🔑 请输入 MySQL root 密码: " ROOT_PASS
        echo "" # 补充换行符，防止排版错乱
        
        # 第二次确认
        read -s -p "🔁 请再次输入密码以确认: " ROOT_PASS_CONFIRM
        echo "" 
        
        # [防御拦截] 校验两次密码是否一致
        if [ "$ROOT_PASS" != "$ROOT_PASS_CONFIRM" ]; then
            echo "❌ 致命错误: 两次输入的密码不一致！"
            echo "🛑 为防止误操作，任务已安全中止，请重新运行指令。"
            exit 1
        fi
        
        # 再次发射探针，使用环境变量注入密码，测试密码是否真实有效
        echo "⏳ 正在校验密码有效性..."
        if env MYSQL_PWD="${ROOT_PASS}" mysql -uroot -e "SELECT 1;" >/dev/null 2>&1; then
            echo "✅ 密码验证通过，引擎响应正常！"
            echo "----------------------------------------------------"
            USE_MANUAL_PASS=true
        else
            echo "❌ 致命错误: 密码错误或数据库服务未运行！"
            echo "🛑 任务已安全中止。"
            exit 1
        fi
    fi

    # --------------------------------------------------
    # 1. 交互式收集情报 (连通性验证通过后才执行)
    # --------------------------------------------------
    read -p "请输入新的【数据库名称】(如 flarum_db): " NEW_DB_NAME
    if [ -z "$NEW_DB_NAME" ]; then
        echo "❌ 错误: 数据库名称不能为空！"
        exit 1
    fi

    read -p "请输入新的【数据库用户名】(如 flarum_user): " NEW_DB_USER
    if [ -z "$NEW_DB_USER" ]; then
        echo "❌ 错误: 用户名不能为空！"
        exit 1
    fi

    read -p "请输入该用户的【数据库密码】: " NEW_DB_PASS
    if [ -z "$NEW_DB_PASS" ]; then
        echo "❌ 错误: 密码不能为空！"
        exit 1
    fi

    echo "⏳ 正在底层引擎中执行物理级隔离与授权..."

    # --------------------------------------------------
    # 2. 准备核心建库 SQL 指令
    # --------------------------------------------------
    SQL_STMT="
    CREATE DATABASE IF NOT EXISTS \`${NEW_DB_NAME}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
    CREATE USER IF NOT EXISTS '${NEW_DB_USER}'@'localhost' IDENTIFIED BY '${NEW_DB_PASS}';
    CREATE USER IF NOT EXISTS '${NEW_DB_USER}'@'%' IDENTIFIED BY '${NEW_DB_PASS}';
    GRANT ALL PRIVILEGES ON \`${NEW_DB_NAME}\`.* TO '${NEW_DB_USER}'@'localhost';
    GRANT ALL PRIVILEGES ON \`${NEW_DB_NAME}\`.* TO '${NEW_DB_USER}'@'%';
    FLUSH PRIVILEGES;
    "

    # --------------------------------------------------
    # 3. 智能分发执行
    # --------------------------------------------------
    if [ "$USE_MANUAL_PASS" = true ]; then
        env MYSQL_PWD="${ROOT_PASS}" mysql -uroot -e "$SQL_STMT"
        EXEC_RESULT=$?
    else
        mysql -e "$SQL_STMT"
        EXEC_RESULT=$?
    fi

    # --------------------------------------------------
    # 4. 结果校验与输出
    # --------------------------------------------------
    if [ $EXEC_RESULT -eq 0 ]; then
		# --------------------------------------------------
		# [新增功能] 追加专属通行证到 ~/.my.cnf (使用后缀隔离组)
		# --------------------------------------------------
		echo "" >> ~/.my.cnf
		echo "[client_${NEW_DB_USER}]" >> ~/.my.cnf
		echo "user = ${NEW_DB_USER}" >> ~/.my.cnf
		echo "password = ${NEW_DB_PASS}" >> ~/.my.cnf
        echo "✅ 数据库隔离空间创建成功！"
        echo "----------------------------------------------------"
        echo "👉 数据库名 : ${NEW_DB_NAME}"
        echo "👉 用户名   : ${NEW_DB_USER}"
        echo "👉 密  码   : ${NEW_DB_PASS}"
        echo "----------------------------------------------------"
        echo "💡 请将以上信息直接填入你新网站的配置文件中。"
    else
        echo "❌ 创建失败！在执行建库 SQL 时发生底层异常。"
    fi
}

# ==========================================
# root 密码全自动修改向导
# ==========================================
function change_root_pw() {
    echo "===================================================="
    echo "🔐 DNMP数据库MariaDB root 密码修改向导"
    echo "===================================================="

    # 1. 探针：检测当前免密通道是否有效
    if ! mysql -e "SELECT 1;" >/dev/null 2>&1; then
        echo "❌ 致命错误: 当前 ~/.my.cnf 的凭据已失效！"
        echo "🛑 必须保证当前通道畅通，才能执行密码修改。请先手动修复 ~/.my.cnf。"
        exit 1
    fi

    echo "✅ 引擎身份验证通过，当前免密通道畅通。"
    echo "----------------------------------------------------"
    echo "💡 提示: 终端已开启静默防窥模式，请放心盲打。"

    # 2. 盲打双重校验获取新密码
    read -s -p "🔑 请输入【新】的 root 密码: " NEW_ROOT_PASS
    echo "" 
    
    read -s -p "🔁 请再次输入新密码确认: " NEW_ROOT_PASS_CONFIRM
    echo "" 

    if [ "$NEW_ROOT_PASS" != "$NEW_ROOT_PASS_CONFIRM" ]; then
        echo "❌ 致命错误: 两次输入的新密码不一致！任务中止。"
        exit 1
    fi

    echo "⏳ 正在更改数据库密码..."

    # 3. 核心手术 1：修改数据库底层的真实密码
    # 涵盖 localhost 和 % 两种常见权限，确保不遗漏
    mysql -e "
    ALTER USER IF EXISTS 'root'@'localhost' IDENTIFIED BY '${NEW_ROOT_PASS}';
    ALTER USER IF EXISTS 'root'@'%' IDENTIFIED BY '${NEW_ROOT_PASS}';
    FLUSH PRIVILEGES;
    "

    if [ $? -ne 0 ]; then
        echo "❌ 密码修改失败！数据库 SQL 引擎拒绝了该操作。"
        exit 1
    fi

    echo "✅ 数据库密码已成功更换！"
    echo "⏳ 正在重新更新本地 ~/.my.cnf 密码..."

    # 4. 核心手术 2：智能修改配置文件 (只改 root 密码，绝不误伤追加的其他用户)
    # 使用 awk 神技：只替换匹配到的【第一个】 password 字段
    awk -v pass="$NEW_ROOT_PASS" '
    !done && /^password[ \t]*=/ { 
        print "password = " pass; 
        done=1; 
        next 
    } 1
    ' ~/.my.cnf > ~/.my.cnf.tmp && mv ~/.my.cnf.tmp ~/.my.cnf

    # 确保权限依然是绝对安全的 600
    chmod 600 ~/.my.cnf

    echo "✅ ~/.my.cnf 密码更新完成！"
    echo "----------------------------------------------------"
    echo "🎉 恭喜！root 密码全套更新流程已闭环！你现在可以随时使用免密通道了。"
}

# ==========================================
# 独立高危模块：Debian 动态嗅探与大版本跨代升级
# 触发方式：bash dnmp os
# ==========================================
function debian_os_upgrade() {
    echo "=================================================="
    echo " 🚨 警告：你正在启动【全动态】系统大版本跨代升级！"
    echo " ⚠️ 执行前请务必确保重要文件已备份！"
    echo "=================================================="
    read -p "确认已备份并继续吗？(输入 yes 确认): " confirm
    if [ "$confirm" != "yes" ]; then
        echo "操作已取消，系统安全退出。"
        return 0
    fi

    # ------------------------------------------
    # 第一阶段：提取本地档案
    # ------------------------------------------
    LOCAL_VERSION=$(cat /etc/debian_version 2>/dev/null || echo "Unknown")
    LOCAL_MAJOR=$(echo "$LOCAL_VERSION" | cut -d. -f1)
    LOCAL_CODENAME=$(lsb_release -cs 2>/dev/null || awk -F= '/^VERSION_CODENAME=/{print $2}' /etc/os-release)

    if [ -z "$LOCAL_MAJOR" ] || [ -z "$LOCAL_CODENAME" ]; then
        echo "❌ 致命错误：无法识别本地 Debian 版本与代号，升级紧急熔断！"
        return 1
    fi
    echo ">>> 本地系统版本: Debian $LOCAL_VERSION (代号: $LOCAL_CODENAME)"
    
    # ------------------------------------------
    # 依赖自愈补丁：检测并安装缺少的组件
    # ------------------------------------------
    if ! command -v curl >/dev/null 2>&1; then
        echo ">>> 状态探测：系统缺少 curl，正在静默安装..."
        export DEBIAN_FRONTEND=noninteractive
        apt-get update -y >/dev/null 2>&1
        apt-get install -y curl >/dev/null 2>&1
        echo "✅ curl 组件安装完毕！"
    fi

    # ------------------------------------------
    # 第二阶段：中美双源动态嗅探最新版本
    # ------------------------------------------
    local URL_CN="https://mirrors.aliyun.com/debian/dists/stable/Release"
    local URL_US="https://ftp.debian.org/debian/dists/stable/Release"
    local RELEASE_CONTENT=""

    echo ">>> 正在向国内源 (Aliyun) 索取最新 OS 档案..."
    RELEASE_CONTENT=$(curl -s --connect-timeout 5 "$URL_CN")

    if [ -z "$RELEASE_CONTENT" ]; then
        echo "⚠️ 国内源响应超时，切换至美国官方源 (Debian.org)..."
        RELEASE_CONTENT=$(curl -s --connect-timeout 5 "$URL_US")
    fi

    if [ -z "$RELEASE_CONTENT" ]; then
        echo "❌ 错误：中美双源请求均失败，请检查物理网络或 DNS 设置！"
        return 1
    fi

    LATEST_VERSION=$(echo "$RELEASE_CONTENT" | awk -F': ' '/^Version:/ {print $2}' | tr -d '\r')
    LATEST_CODENAME=$(echo "$RELEASE_CONTENT" | awk -F': ' '/^Codename:/ {print $2}' | tr -d '\r')
    LATEST_MAJOR=$(echo "$LATEST_VERSION" | cut -d. -f1)

    if [ -z "$LATEST_VERSION" ] || [ -z "$LATEST_CODENAME" ]; then
        echo "❌ 错误：源连接成功，但 Release 文件解析失败！"
        return 1
    fi
    echo "✅ 成功截获线上最新稳定版：Debian $LATEST_VERSION (代号: $LATEST_CODENAME)"

    # ------------------------------------------
    # 第三阶段：逻辑校验与安全锁
    # ------------------------------------------
    if [ "$LOCAL_MAJOR" == "$LATEST_MAJOR" ]; then
        echo "🎉 结论：当前大版本 (v$LOCAL_MAJOR) 已是线上最新，无需跨代升级！"
        return 0
    fi

    if [ "$LOCAL_MAJOR" -gt "$LATEST_MAJOR" ]; then
         echo "🤔 结论：当前版本高于线上稳定版 (可能在使用 testing 分支)，跳过升级。"
         return 0
    fi

    # 【防手残安全锁】：使用现代 Bash 语法运算
    local MAX_ALLOWED_MAJOR=$((LOCAL_MAJOR + 1))
    if [ "$LATEST_MAJOR" -gt "$MAX_ALLOWED_MAJOR" ]; then
        echo "❌ 绝对禁止：线上最新版本为 v$LATEST_MAJOR，你的版本为 v$LOCAL_MAJOR。"
        echo "❌ 跨越多代升级会100%导致内核库雪崩，必须手动逐代升级！脚本紧急熔断。"
        return 1
    fi

    echo ">>> 校验通过：准备从 $LOCAL_CODENAME 跨代跃迁至 $LATEST_CODENAME ..."

    # ------------------------------------------
    # 第四阶段：核心手术与两段式升级
    # ------------------------------------------
    echo "-> 正在全盘备份并动态重写 APT 软件源..."
    cp -a /etc/apt "/etc/apt.bak_$(date +%F_%H%M%S)"

    # 1. 扫描网络
    detect_region >/dev/null 2>&1

    # 2. 替换系统源
    replace_system_sources "$LATEST_CODENAME"

    echo "-> 正在临时挂起第三方扩展源 (Docker/Nginx/PHP 等)..."
    for ext_file in /etc/apt/sources.list.d/*.list /etc/apt/sources.list.d/*.sources; do
        # 存在性防御
        [ -e "$ext_file" ] || continue
        # 排除咱们的标准化系统底座
        if [[ "$ext_file" != *"/debian.list" && "$ext_file" != *"/debian.sources" ]]; then
            mv "$ext_file" "${ext_file}.disabled" 2>/dev/null || true
        fi
    done

    export DEBIAN_FRONTEND=noninteractive
    echo "-> [1/3] 拉取新系统 ($LATEST_CODENAME) 基础索引..."
    apt-get update -y

    echo "-> [2/3] 第一段：最小化平滑过渡升级..."
    apt-get upgrade --without-new-pkgs -y -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confold"

    echo "-> [3/3] 第二段：核心 Full-Upgrade 跨代大升级..."
    apt-get full-upgrade -y -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confold"

    echo "-> 清理残骸并恢复第三方扩展源..."
    apt-get autoremove -y && apt-get clean
    
    for disabled_file in /etc/apt/sources.list.d/*.disabled; do
        [ -e "$disabled_file" ] || continue
        mv "$disabled_file" "${disabled_file%.disabled}" 2>/dev/null || true
    done

    # 【补丁】：恢复源后静默更新一次索引，防止缓存断层
    echo "-> 正在刷新全局索引以适配已恢复的扩展源..."
    apt-get update -y >/dev/null 2>&1

    echo -e ""
    print_green "==================================================\n"
    print_green " 🎉 恭喜！全动态跨代升级 ($LATEST_CODENAME) 执行完毕！\n"
    print_warn  " ⚠️ 新内核已注入，请择机手动执行 reboot 重启系统。\n"
    print_green "==================================================\n"
    echo -e ""
}

